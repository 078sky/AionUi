{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES2023"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "declaration": true
  },
  "include": ["src/**/*"]
}
